# ─── Alpha CLI – Environment Variables ───────────────────────────────

# Backend URL (required)
# Should point to your backend API, e.g., http://localhost:4000/api
BACKEND_URL=http://localhost:4000/api

# Frontend URL (required for browser-based login)
# Should point to your Next.js UI, e.g., http://localhost:3000
FRONTEND_URL=http://localhost:3000
