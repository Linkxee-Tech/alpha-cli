# ─── Alpha CLI Backend – Environment Variables ───────────────────────────────

# MongoDB connection string (required)
MONGO_URI=mongodb://localhost:27017/alpha_cli

# JWT signing secret – change this to a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# Nansen API Key – leave blank to use built-in mock data
NANSEN_API_KEY=

# Server port (optional, defaults to 4000)
PORT=4000
